<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  UAS stub — answers the bridge's outbound INVITE with 486 Busy Here.
  Bridge maps 486 to DialCallStatus=busy and BYEs the inbound leg with
  Reason: SIP;cause=486.

  Used by: inbound-rest-dial-busy.xml (scenario c).
-->

<scenario name="uas-busy">
  <recv request="INVITE">
    <action>
      <log message="UAS busy: received INVITE"/>
    </action>
  </recv>

  <send>
    <![CDATA[

      SIP/2.0 100 Trying
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <send retrans="500">
    <![CDATA[

      SIP/2.0 486 Busy Here
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Reason: SIP;cause=486;text="Busy here"
      Content-Length: 0

    ]]>
  </send>

  <recv request="ACK" optional="true" rtd="true" crlf="true"/>

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>

</scenario>
