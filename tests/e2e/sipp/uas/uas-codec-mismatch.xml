<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  UAS stub — answers INVITE with 200 OK but advertises G.722 only in
  the SDP. The bridge is PCMU-only at the SIP layer (codec discipline);
  it cannot transcode, so it ACKs the 200, immediately sends BYE on
  the dial leg, and propagates "failed" to the inbound leg.

  Used by: inbound-rest-dial-codec-mismatch.xml (scenario f).
-->

<scenario name="uas-codec-mismatch">
  <recv request="INVITE">
    <action>
      <log message="UAS codec-mismatch: received INVITE; will answer 200 OK with G.722-only SDP"/>
    </action>
  </recv>

  <send>
    <![CDATA[

      SIP/2.0 100 Trying
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <send retrans="500">
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[service]@[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 9
      a=rtpmap:9 G722/8000
      a=sendrecv

    ]]>
  </send>

  <recv request="ACK" rtd="true" crlf="true"/>

  <!-- Bridge detects codec mismatch (PCMU offered, G.722 answered) and
       BYEs the dial leg shortly after ACK. -->
  <recv request="BYE" rtd="true" timeout="5000"/>

  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>

</scenario>
