<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  UAS stub — slow ringing. Receives INVITE, sends 100 Trying then
  180 Ringing, then waits for the bridge's CANCEL (triggered when the
  inbound caller BYEs during the dial-leg ringing window) and replies
  487 Request Terminated.

  Used by: inbound-rest-dial-cancel.xml (scenario e).
-->

<scenario name="uas-slow-ring">
  <recv request="INVITE">
    <action>
      <log message="UAS slow-ring: received INVITE; will ring then wait for CANCEL"/>
    </action>
  </recv>

  <send>
    <![CDATA[

      SIP/2.0 100 Trying
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <send>
    <![CDATA[

      SIP/2.0 180 Ringing
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[service]@[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0

    ]]>
  </send>

  <!-- Wait for CANCEL (triggered when the inbound caller hangs up). -->
  <recv request="CANCEL" rtd="true" timeout="10000">
    <action>
      <log message="UAS slow-ring: received CANCEL"/>
    </action>
  </recv>

  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <send retrans="500">
    <![CDATA[

      SIP/2.0 487 Request Terminated
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      CSeq: 1 INVITE
      Content-Length: 0

    ]]>
  </send>

  <recv request="ACK" optional="true" rtd="true" crlf="true"/>

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>

</scenario>
