<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  UAS stub — answers the bridge's outbound INVITE with 200 OK + PCMU SDP,
  pauses 1.5s, then sends BYE on the dial leg. The bridge relays the BYE
  to the inbound leg, which the UAC scenario observes.

  Used by: inbound-rest-dial-answer.xml (scenario b).

  sipp wires this in as `sipp -sf uas/uas-answer.xml -p $UAS_PORT -m 1`.
  The PCMU SDP advertises media-port 6000 — the bridge's outbound INVITE
  carries its own offer; sipp's SDP is the answer.
-->

<scenario name="uas-answer">
  <recv request="INVITE">
    <action>
      <ereg regexp=".*" search_in="hdr" header="Call-ID:" check_it="true" assign_to="callid"/>
      <log message="UAS answer: received INVITE [$callid]"/>
    </action>
  </recv>

  <send>
    <![CDATA[

      SIP/2.0 100 Trying
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <send retrans="500">
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[service]@[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0 101
      a=rtpmap:0 PCMU/8000
      a=rtpmap:101 telephone-event/8000
      a=fmtp:101 0-16
      a=sendrecv

    ]]>
  </send>

  <recv request="ACK" rtd="true" crlf="true">
    <action>
      <!-- Capture the bridge's Contact URI from the ACK so the BYE
           Request-URI lands on the bridge listener. The harness binds
           the bridge to 127.0.0.1:$BRIDGE_SIP_PORT (default 5070) and
           Contact: <sip:testuser@127.0.0.1:5070> per registrar.go. -->
      <ereg regexp="sip:[^>]+" search_in="hdr" header="Contact:" assign_to="contact_uri" check_it="true"/>
    </action>
  </recv>

  <pause milliseconds="1500"/>

  <send retrans="500">
    <![CDATA[

      BYE [$contact_uri] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      From: [last_To:]
      To: [last_From:]
      [last_Call-ID:]
      CSeq: 2 BYE
      Contact: <sip:[service]@[local_ip]:[local_port];transport=[transport]>
      Max-Forwards: 70
      Content-Length: 0

    ]]>
  </send>

  <recv response="200" crlf="true"/>

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>

</scenario>
