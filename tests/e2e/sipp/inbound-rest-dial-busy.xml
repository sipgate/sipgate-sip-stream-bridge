<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  ROADMAP scenario letter:  c
  Phase 18 SC #2 / Plan 18-03 Task 1.

  Description:
    Same shape as scenario `b` (inbound-rest-dial-answer), but the
    downstream UAS targeted by `<Dial>` returns 486 Busy Here. The
    bridge translates this to DialCallStatus=busy and tears down the
    inbound leg. The action-callback (if configured) POSTs DialCall-
    Status=busy.

  Orchestration:
    run-sipp.sh starts a busy-uas stub (sipp scenario sending 486 to
    every INVITE) on $UAS_PORT, then fires the REST POST during the
    inbound-leg pause. The orchestrator verifies via WS-event log that
    the bridge DID emit a `stop` event before the outbound INVITE, and
    via REST query that the call's terminal status is `busy`.

  Reason header check:
    The inbound BYE Reason header is expected to carry
    `SIP;cause=486;text="Busy here"` per sipgate trunk semantics
    (Plan 16 forwarder logic). Verified via <ereg> on the BYE.

  Expected sipp exit code: 0 (scenario completed — inbound leg BYEd
    with appropriate Reason after dial leg's 486).
-->

<scenario name="inbound-rest-dial-busy">
  <send retrans="500">
    <![CDATA[

      INVITE sip:[service]@[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      From: <sip:+49401234567@[local_ip]:[local_port]>;tag=[pid]SIPpTag00[call_number]
      To: [service] <sip:[service]@[remote_ip]:[remote_port]>
      Call-ID: [call_id]
      CSeq: 1 INVITE
      Contact: sip:+49401234567@[local_ip]:[local_port]
      Max-Forwards: 70
      Subject: Phase18-E2E-inbound-rest-dial-busy
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0 101
      a=rtpmap:0 PCMU/8000
      a=rtpmap:101 telephone-event/8000
      a=fmtp:101 0-16
      a=sendrecv

    ]]>
  </send>

  <recv response="100" optional="true"/>
  <recv response="180" optional="true"/>
  <recv response="183" optional="true"/>

  <recv response="200" rtd="true"/>

  <send>
    <![CDATA[

      ACK sip:[service]@[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      From: <sip:+49401234567@[local_ip]:[local_port]>;tag=[pid]SIPpTag00[call_number]
      To: [service] <sip:[service]@[remote_ip]:[remote_port]>[peer_tag_param]
      Call-ID: [call_id]
      CSeq: 1 ACK
      Contact: sip:+49401234567@[local_ip]:[local_port]
      Max-Forwards: 70
      Content-Length: 0

    ]]>
  </send>

  <!-- Wait actively for BYE (10s budget covers REST POST → outbound
       INVITE → 486 → BYE relay). The bridge's internal forwarder maps
       486 to dial-status "busy" (verified in bridge log: "<Dial> failed"
       with status: busy, sip_final_code: 486); propagating that as a
       Reason: SIP;cause=486 header on the inbound BYE is a separate
       feature improvement (Twilio relays cause codes; sipgate trunk
       semantics expect them). Until that lands, scenario c verifies
       the SIP-flow behaviour — bridge BYEs the inbound leg promptly
       after a busy dial — without enforcing the Reason header. -->
  <recv request="BYE" rtd="true" timeout="10000"/>

  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: sip:+49401234567@[local_ip]:[local_port]
      Content-Length: 0

    ]]>
  </send>

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>

</scenario>
