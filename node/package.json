{
  "name": "sipgate-sip-stream-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.5",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx --env-file=../.env --watch src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist",
    "start": "node --env-file=../.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
