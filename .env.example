# sipgate-sip-stream-bridge environment configuration
# Copy this file to .env and fill in your sipgate credentials.
# .env is gitignored; .env.example is committed.

# ─── Required ────────────────────────────────────────────────────────────────

# Your sipgate SIP-ID (found in sipgate portal under "Connections > SIP Trunks")
# Format: eNNNNNpN (e.g. e12345p0)
SIP_USER=

# SIP password for the above SIP-ID
SIP_PASSWORD=

# SIP registrar domain (MEDIUM confidence: verify from sipgate portal)
# The registrar hostname used in the SIP From/To URI domain part.
SIP_DOMAIN=sipconnect.sipgate.de

# SIP registrar hostname — sipgate trunking uses standard SIP over UDP (port 5060)
SIP_REGISTRAR=sipconnect.sipgate.de

# ── WS target (mutually exclusive with VOICE_URL — set exactly one) ──────────
# Static WebSocket URL — the AI voice backend that receives Twilio Media Streams events.
# Use this for simple deployments where every call goes to the same WS endpoint.
WS_TARGET_URL=ws://localhost:8080

# Dynamic Voice URL — Twilio-compatible webhook that returns TwiML <Connect><Stream>
# per call. The bridge POSTs call metadata and uses the WS URL from the response.
# Use this when your platform assigns a different WS URL per call (e.g. multi-tenant).
# Mutually exclusive with WS_TARGET_URL — comment out WS_TARGET_URL to use these.
# VOICE_URL=https://your-platform.example/twiml/voice
# VOICE_METHOD=POST
# VOICE_FALLBACK_URL=https://backup.example/twiml/voice
# VOICE_FALLBACK_METHOD=POST
# VOICE_TIMEOUT_S=5

# ─── Optional (have defaults) ─────────────────────────────────────────────────

# External/reachable IP of this host for SIP Via: and SDP Contact: headers.
# REQUIRED when running behind NAT: set to your public IP (curl -s ifconfig.me).
# Without this, sipgate advertises your private IP in SDP and RTP never arrives.
# SDP_CONTACT_IP=203.0.113.10

# UDP port range for RTP media sockets (one socket per concurrent call).
# Default 100-port range supports ~50 concurrent calls.
# RTP_PORT_MIN=10000
# RTP_PORT_MAX=10099

# SIP registration expiry in seconds. Registerer auto-renews at 90% of this value.
# SIP_EXPIRES=120

# Interval in seconds between SIP OPTIONS keepalive pings to the registrar.
# Two consecutive failures (timeout or non-auth error) trigger a re-registration.
# SIP_OPTIONS_INTERVAL=30

# Log level: trace | debug | info | warn | error
# LOG_LEVEL=info

# Audio codec mode.
#   twilio  (default) — PCMU/G.711 μ-law 8 kHz. Backwards-compatible with all Twilio-style
#           backends. mediaFormat in the start event: {"encoding":"audio/x-mulaw","sampleRate":8000}
#   best    — Negotiates the highest-quality codec sipgate offers: G.722 (16 kHz wideband) >
#           PCMA (A-law 8 kHz) > PCMU (μ-law 8 kHz). The negotiated codec is reported in the
#           start event's mediaFormat so the backend knows what encoding it receives and must send.
#           G.722 example: {"encoding":"audio/G722","sampleRate":16000}
#           RTP payload is passed through unchanged — the backend handles encoding/decoding.
# AUDIO_MODE=twilio

# SRTP media encryption.
#   false (default) — plain RTP (unencrypted) used for all calls.
#   true  or 1      — negotiate SRTP (RTP/SAVP) with sipgate when the caller's SDP offer
#                     advertises RTP/SAVP. Key exchange uses SDES (RFC 4568) with the
#                     AES_128_CM_HMAC_SHA1_80 cipher suite. Falls back to plain RTP/AVP
#                     automatically when the caller's offer is plain RTP/AVP.
# SRTP_ENABLED=false

# ─── v3.0 control plane ──────────────────────────────────────────────────────

# Twilio-compatible auth token — used as the HMAC-SHA1 signing key for X-Twilio-Signature
# AND as the HTTP Basic Auth password for /2010-04-01/... REST endpoints.
# AUTH_TOKEN=

# External base URL when the bridge runs behind a reverse proxy (TLS terminator, ingress, etc.).
# Used to reconstruct the signed URL for HMAC computation so signatures match what the
# client originally sent. Honors X-Forwarded-Proto / X-Forwarded-Host as a fallback.
# PUBLIC_BASE_URL=https://bridge.example.com

# ─── v3.0 <Dial> / B2BUA Call Forwarding ─────────────────────────────────────

# Toll-fraud allow-list — CSV of E.164 prefixes. EMPTY = DENY ALL (default).
# Operator MUST opt in by setting at least one prefix to enable any <Dial>.
# Each entry must match ^\+?[0-9]+$ (optional leading '+', then digits only).
# Examples:
#   DIAL_ALLOWED_PREFIXES=+49           (Germany only)
#   DIAL_ALLOWED_PREFIXES=+49,+44,+1    (DE, UK, US)
# DIAL_ALLOWED_PREFIXES=

# Explicit caller-ID for <Dial> when the TwiML callerId attribute is empty.
# Overrides the SIP_USER auto-fallback. Set this to a verified outbound DID on
# your trunk if you want Phone B to see a phone number instead of the SIP
# authentication username (sipgate trunks reject any From that isn't the
# SIP_USER, so by default Phone B sees e.g. "2301086t3" — functional, ugly).
# DIAL_DEFAULT_CALLER_ID=+4915123456789

# E.164 country code (without "+") used to normalise display caller-IDs into
# the format sipgate's trunking documentation requires for the From display-
# name and the P-Preferred-Identity user-part: international format without
# leading "+" or "00", and without leading "0" on the area code.
#   "021193674951"     → "4921193674951"  (with cc=49)
#   "+4921193674951"   → "4921193674951"
#   "004921193674951"  → "4921193674951"
# Empty = only strip leading "+" / "00", leave national numbers as-is.
# Reference: https://help.sipgate.de/trunking/wie-setze-ich-bei-sipgate-trunking-die-absenderrufnummer
# DIAL_CALLER_ID_COUNTRY_CODE=49

# Default ring timeout in seconds (5–600). Overridable per-Dial via TwiML timeout=.
# DIAL_RING_TIMEOUT_S=30

# Rate limits (toll-fraud / overload defense).
#   DIAL_MAX_PER_SESSION — max <Dial> calls per inbound session lifetime
#   DIAL_MAX_PER_MINUTE  — max outbound dials per rolling 60-second window (global)
# DIAL_MAX_PER_SESSION=3
# DIAL_MAX_PER_MINUTE=60
